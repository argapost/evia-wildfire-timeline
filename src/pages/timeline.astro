---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineWorkspace from '../components/timeline/TimelineWorkspace.tsx';
---

<BaseLayout title="Timeline | Evia Wildfire Timeline">
  <nav class="timeline-nav" aria-label="Section navigation">
    <a href="/timeline" class="timeline-nav-tab is-active">_Planning &amp; Policy</a>
    <a href="#" class="timeline-nav-tab">_Forestry Service</a>
    <a href="/home" class="timeline-nav-tab">_Hybrid Schemes</a>
  </nav>
  <TimelineWorkspace client:load />

  <script>
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      // If the click is inside the timeline SVG area, nav links, or interactive panels — do nothing
      if (
        target.closest('.timeline-host') ||
        target.closest('.timeline-nav') ||
        target.closest('.timeline-toolbar') ||
        target.closest('a') ||
        target.closest('button')
      ) {
        return;
      }
      window.location.href = '/presentation/reconstruction';
    });
  </script>
</BaseLayout>
